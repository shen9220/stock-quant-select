{
  "name": "智能选股助手",
  "description": "基于A股市场数据的智能选股工具，支持多维度筛选、估值分析、技术指标评分",
  "version": "1.0.0",
  "type": "skill",
  "skill_id": "stock-assistant",
  "skill_path": "/workspace/projects/stock-quant-select/downloaded_skills/stock-assistant",

  "config": {
    "trigger_words": [
      "选股",
      "帮我选股",
      "股票推荐",
      "分析股票",
      "分析",
      "这只股票怎么样",
      "找股票",
      "推荐股票",
      "股票分析",
      "选几只",
      "能买",
      "高股息",
      "股息率",
      "热门",
      "热点",
      "板块"
    ],

    "data_source": {
      "realtime": "腾讯财经 API",
      "history": "东方财富 API",
      "financial": "新浪财经 API"
    },

    "scoring": {
      "valuation": {
        "formula": "100 - PE百分位 × 0.5 - PB百分位 × 0.3 - PEG偏离度 × 0.2",
        "levels": {
          "excellent": [80, 100],
          "good": [60, 80],
          "fair": [40, 60],
          "poor": [0, 40]
        }
      },
      "technical": {
        "formula": "均线评分(30%) + 量价评分(25%) + 动量评分(25%) + 形态评分(20%)",
        "levels": {
          "strong": [85, 100],
          "recommended": [70, 84],
          "watch": [55, 69],
          "cautious": [40, 54],
          "avoid": [0, 39]
        }
      }
    },

    "limits": {
      "max_stocks_per_query": 50,
      "max_api_calls_per_day": 100,
      "trading_hours": ["09:30", "15:00"]
    },

    "risk_warning": {
      "enabled": true,
      "messages": [
        "本工具仅供参考，不构成投资建议",
        "股市有风险，投资需谨慎",
        "建议分散投资，控制单一标的仓位"
      ]
    }
  },

  "capabilities": {
    "smart_selection": {
      "enabled": true,
      "description": "根据用户偏好筛选符合条件的股票",
      "dimensions": [
        "行业板块",
        "市值范围",
        "估值水平",
        "涨跌幅",
        "股息率",
        "技术形态"
      ]
    },
    "valuation_scoring": {
      "enabled": true,
      "description": "基于 PE/PB 历史百分位评估当前估值水平"
    },
    "technical_scoring": {
      "enabled": true,
      "description": "结合均线、成交量、涨跌幅等指标给出技术面评分"
    },
    "industry_comparison": {
      "enabled": true,
      "description": "将目标股票与同行业公司进行多维度对比"
    },
    "investment_advice": {
      "enabled": true,
      "description": "综合评分后给出买入/观望/回避建议"
    }
  },

  "usage_scenarios": [
    "帮我选几只低估值的银行股",
    "我想买新能源，有什么推荐的吗？",
    "这只股票能买吗？帮我分析一下",
    "帮我找几只高股息的股票",
    "最近什么板块比较热门？"
  ],

  "dependencies": {
    "python": {
      "packages": [
        {"name": "requests", "version": ">=2.25.0"},
        {"name": "pandas", "version": ">=1.3.0"},
        {"name": "numpy", "version": ">=1.20.0"}
      ]
    },
    "optional": {
      "packages": [
        {"name": "akshare", "version": ">=1.0.0", "description": "更丰富的A股数据"}
      ]
    }
  },

  "author": "虾叨叨",
  "license": "MIT",
  "updated": "2026-03-19"
}
